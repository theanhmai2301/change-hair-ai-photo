<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="com.google.android.gms.permission.AD_ID" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <application
        android:name=".HairStyleApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.HairStyleAI">

        <!-- Launcher + first-open orchestrator -->
        <activity
            android:name=".firstopen.SplashActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.HairStyleAI.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- First-open flow -->
        <activity android:name=".firstopen.language.LanguageFO1Activity"
            android:exported="false" android:screenOrientation="portrait" />
        <activity android:name=".firstopen.language.LanguageFO2Activity"
            android:exported="false" android:screenOrientation="portrait" />
        <activity android:name=".firstopen.survey.SurveyActivity"
            android:exported="false" android:screenOrientation="portrait" />
        <activity android:name=".firstopen.survey.SurveyDupActivity"
            android:exported="false" android:screenOrientation="portrait" />
        <activity android:name=".firstopen.survey.Survey3Activity"
            android:exported="false" android:screenOrientation="portrait" />
        <activity android:name=".firstopen.onboarding.OnBoardingActivity"
            android:exported="false" android:screenOrientation="portrait" />
        <activity android:name=".firstopen.PermissionActivity"
            android:exported="false" android:screenOrientation="portrait" />

        <!-- Main app -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.HairStyleAI" />

        <!-- Gives the system camera a content:// URI to write the capture into. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>
