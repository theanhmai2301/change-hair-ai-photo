<?xml version="1.0" encoding="utf-8"?>
<!-- LIGHT theme palette (Beauty AI). Dark values live in values-night/colors.xml; the
     same token names resolve to those in dark mode. Accent / danger / white are shared. -->
<resources>
    <!-- Brand accent (emerald, shared both themes) -->
    <color name="accent">#00D2A0</color>
    <color name="accent_dark">#00B87C</color>
    <color name="accent_secondary">#12E8B6</color>
    <color name="accent_bright">#4FFFD1</color>
    <color name="accent_border">#00E1AF</color>
    <color name="accent_12">#1F00D2A0</color>
    <color name="accent_25">#4000D2A0</color>

    <!-- Light surfaces / background (clean beauty surfaces, soft depth) -->
    <color name="bg_top">#FCFDFF</color>
    <color name="bg_bottom">#F1F8F5</color>
    <color name="surface">#FFFFFF</color>
    <color name="surface_deep">#F7FAF9</color>

    <!-- Premium-soft selected tile -->
    <color name="tile_selected">#EAFBF5</color>

    <!-- Secondary button (camera / hair category / secondary actions) -->
    <color name="btn2_bg">#F1FCF9</color>
    <color name="btn2_border">#B7F2DE</color>
    <color name="btn2_text">#00A878</color>

    <!-- Text -->
    <color name="text_primary">#17181F</color>
    <color name="text_muted">#7A7D89</color>
    <color name="text_disabled">#B8BCC7</color>

    <!-- Status -->
    <color name="danger">#EF4444</color>
    <color name="danger_soft">#DC2626</color>
    <color name="danger_12">#1FEF4444</color>

    <!-- On-accent text / icons stay white in both themes -->
    <color name="white">#FFFFFF</color>
    <color name="hairline">#E8F2EF</color>

    <!-- App-icon dark backdrop (splash) -->
    <color name="splash_bg">#0A0530</color>
</resources>
