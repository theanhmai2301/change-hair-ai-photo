<?xml version="1.0" encoding="utf-8"?>
<!-- Primary CTA: emerald gradient when enabled, flat surface when disabled. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/surface_deep" />
            <stroke android:width="1dp" android:color="@color/hairline" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:startColor="@color/accent"
                android:endColor="@color/accent_dark"
                android:type="linear" />
            <corners android:radius="24dp" />
        </shape>
    </item>
</selector>
