<?xml version="1.0" encoding="utf-8"?>
<!-- Self-contained launcher icon (works on all API levels, no PNGs needed):
     accent gradient tile + white scissors glyph. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="@color/accent"
                android:endColor="@color/accent_dark"
                android:type="linear" />
            <corners android:radius="22dp" />
        </shape>
    </item>
    <item
        android:width="56dp"
        android:height="56dp"
        android:drawable="@drawable/ic_scissors"
        android:gravity="center" />
</layer-list>
