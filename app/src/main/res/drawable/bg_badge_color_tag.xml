<?xml version="1.0" encoding="utf-8"?>
<!-- "Color applied" tag — multicolor pill to read as a hair-color layer. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:startColor="#F4A6C0"
        android:centerColor="#B39DDB"
        android:endColor="#7EC8E3"
        android:angle="0"
        android:type="linear" />
    <corners android:radius="999dp" />
</shape>
