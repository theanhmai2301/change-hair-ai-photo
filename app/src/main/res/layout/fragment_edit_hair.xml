<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:paddingHorizontal="20dp"
    android:paddingTop="12dp"
    android:paddingBottom="20dp">

    <!-- ── Header ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="8dp">

        <FrameLayout
            android:id="@+id/backButton"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/bg_icon_button"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_arrow_left"
                android:tint="@color/text_primary"
                android:contentDescription="@string/cd_back" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/edit_title"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/edit_subtitle"
                android:textColor="@color/text_muted"
                android:textSize="12sp" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/restoreButton"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/bg_icon_button"
            android:clickable="true"
            android:enabled="false"
            android:focusable="true">

            <ImageView
                android:id="@+id/restoreIcon"
                android:layout_width="17dp"
                android:layout_height="17dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_restore"
                android:tint="@color/text_disabled"
                android:contentDescription="@string/restore" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/saveButton"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_icon_button"
            android:clickable="true"
            android:enabled="false"
            android:focusable="true">

            <ImageView
                android:id="@+id/saveIcon"
                android:layout_width="17dp"
                android:layout_height="17dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_download"
                android:tint="@color/text_disabled"
                android:contentDescription="@string/save" />
        </FrameLayout>
    </LinearLayout>

    <!-- ── Photo preview (flexible height so the preset grid gets real room) ── -->
    <FrameLayout
        android:id="@+id/previewWrap"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_preview">

        <ImageView
            android:id="@+id/previewImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_preview"
            android:clipToOutline="true"
            android:scaleType="fitCenter"
            android:contentDescription="@null" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/scrim_bottom" />

        <!-- Report flag (top-right) — only after a result is generated -->
        <FrameLayout
            android:id="@+id/reportButton"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_gravity="top|end"
            android:layout_margin="12dp"
            android:background="@drawable/bg_badge_glass"
            android:visibility="gone"
            tools:visibility="visible">

            <ImageView
                android:layout_width="17dp"
                android:layout_height="17dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_flag"
                android:tint="@color/white"
                android:contentDescription="@string/cd_report" />
        </FrameLayout>

        <!-- AI badge (top-left) -->
        <LinearLayout
            android:id="@+id/aiBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_margin="12dp"
            android:background="@drawable/bg_badge_glass"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="10dp"
            android:paddingVertical="5dp">

            <ImageView
                android:id="@+id/aiBadgeIcon"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_sparkles"
                android:tint="@color/text_muted"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/aiBadgeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="@string/badge_unedited"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- applied-preset tags (bottom-left): one per generated layer -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_margin="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/colorTag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:background="@drawable/bg_badge_color_tag"
                android:paddingHorizontal="12dp"
                android:paddingVertical="5dp"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="🎨 Baby Blue"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/cutTag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_preset"
                android:paddingHorizontal="12dp"
                android:paddingVertical="5dp"
                android:textColor="@color/bg_bottom"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="✂️ Afro curls"
                tools:visibility="visible" />
        </LinearLayout>

        <!-- processing overlay -->
        <FrameLayout
            android:id="@+id/processingOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_processing_scrim"
            android:visibility="gone"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_loader_box">

                    <ProgressBar
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:indeterminateTint="@color/accent" />
                </FrameLayout>

                <TextView
                    android:id="@+id/processingStep"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_step_pill"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="@string/step_analyze"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/processingDots"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal" />
            </LinearLayout>
        </FrameLayout>
    </FrameLayout>

    <!-- ── Error banner ── -->
    <LinearLayout
        android:id="@+id/errorBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_error_banner"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:visibility="gone"
        tools:visibility="visible">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_alert"
            android:tint="@color/danger_soft"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/errorText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textColor="@color/danger_soft"
            android:textSize="12sp"
            tools:text="Đã xảy ra lỗi, vui lòng thử lại." />
    </LinearLayout>

    <!-- ── Hair tabs ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_segment_track"
        android:orientation="horizontal"
        android:padding="4dp">

        <TextView
            android:id="@+id/tabCut"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/bg_segment_selected"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/tab_cut"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tabColor"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/tab_color"
            android:textColor="@color/text_muted"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/hintText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/hint_cut"
        android:textColor="@color/text_muted"
        android:textSize="11sp" />

    <!-- ── Preset grid (with loading / error states) ── -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/presetGrid"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:overScrollMode="never"
            tools:listitem="@layout/item_preset" />

        <ProgressBar
            android:id="@+id/presetsLoading"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:indeterminateTint="@color/accent"
            android:visibility="gone" />

        <TextView
            android:id="@+id/presetsError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:paddingHorizontal="24dp"
            android:text="@string/presets_error"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:visibility="gone" />
    </FrameLayout>

    <!-- ── Apply ── -->
    <LinearLayout
        android:id="@+id/applyButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_btn_primary"
        android:clickable="true"
        android:enabled="false"
        android:focusable="true"
        android:gravity="center"
        android:orientation="horizontal">

        <ProgressBar
            android:id="@+id/applySpinner"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:indeterminateTint="@color/white"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/applyIcon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_scissors"
            android:tint="@color/text_disabled"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/applyText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/apply_hair"
            android:textColor="@color/text_disabled"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
