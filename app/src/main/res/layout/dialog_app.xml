<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="24dp">

    <ImageView
        android:id="@+id/dialogIcon"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_marginBottom="14dp"
        android:src="@drawable/ic_check_circle"
        android:tint="@color/accent"
        android:contentDescription="@null"
        tools:ignore="UseAppTint" />

    <TextView
        android:id="@+id/dialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        tools:text="Đã lưu ảnh" />

    <TextView
        android:id="@+id/dialogMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:lineSpacingExtra="2dp"
        android:textColor="@color/text_muted"
        android:textSize="14sp"
        tools:text="Ảnh đã được lưu vào thư viện. Bạn muốn chọn ảnh khác để tạo kiểu mới không?" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/dialogNegative"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:background="@drawable/bg_dialog_btn_ghost"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="Ở lại" />

        <Space
            android:layout_width="12dp"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/dialogPositive"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:background="@drawable/bg_dialog_btn_accent"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="Chọn ảnh khác" />
    </LinearLayout>
</LinearLayout>
